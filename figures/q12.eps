1 GC
N
0 0 800 600 re
f
GR
GS
[0.4799 0 0 0.48 0 24] CT
[1 0 0 1 0 0] CT
N
0 -50 M
1667 -50 L
1667 1200 L
0 1200 L
0 -50 L
cp
clip
GS
0 0 translate
1600 1200 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 1200
  /ImageMatrix [1600 0 0 1200 0 0]
  /Width 1600
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
